{
  "name": "nansenterm",
  "version": "1.0.0",
  "description": "The Hacker's Bloomberg Terminal — Interactive TUI for Nansen CLI",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "nansenterm": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.tsx",
    "demo": "tsx src/index.tsx",
    "mock": "node --env-file=.env --import tsx/esm src/index.tsx",
    "build": "tsc",
    "start": "node dist/index.js"
  },
  "keywords": [
    "nansen",
    "cli",
    "tui",
    "crypto",
    "terminal",
    "bloomberg"
  ],
  "author": "edycutjong",
  "license": "MIT",
  "dependencies": {
    "ink": "^5.2.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
